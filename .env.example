# New Restaurant Center — runs against the CGOPS Platform Supabase project
# (the same project as People Center and every other CGOPS application).
# Copy to .env and fill in values (CGOPS dashboard → Settings → API).
# Server-side secrets (service role key) NEVER go here — the frontend uses
# the anon key only, with RLS protecting the data.

# Base project URL ONLY — must NOT include /rest/v1/.
#   e.g. https://<CGOPS_PROJECT_REF>.supabase.co
VITE_SUPABASE_URL=https://<CGOPS_PROJECT_REF>.supabase.co

# Public anonymous key (safe in the browser; RLS is the enforcement layer).
VITE_SUPABASE_ANON_KEY=

# CGOPS Platform URL — the front door. New Restaurant Center has no standalone
# login: unauthenticated visits redirect here, and CGOPS relaunches this app
# with the SSO handoff fragment (#cgops_sso=1&access_token=...&refresh_token=...).
VITE_CGOPS_URL=
